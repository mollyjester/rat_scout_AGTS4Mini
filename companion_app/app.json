{
  "configVersion": "v2",
  "app": {
    "appId": 1000090,
    "appName": "Rat Scout Settings",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "mollyjester",
    "description": "Settings companion for the Rat Scout watchface"
  },
  "permissions": [
    "device:app-side.network"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "1.0.0",
      "target": "1.0.1",
      "minVersion": "1.0.0"
    }
  },
  "targets": {
    "gts4mini": {
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "name": "gts4mini",
          "deviceSource": 246
        },
        {
          "name": "gts4mini-w",
          "deviceSource": 247
        }
      ],
      "designWidth": 336
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Rat Scout Settings"
    }
  },
  "defaultLanguage": "en-US",
  "debug": false
}
